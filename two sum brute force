import java.util.Scanner;
public class Main
{
	public static void main(String[] args){
	    Scanner sc = new Scanner(System.in); 
		int arr[] = {1,2,3,4,5};
		int len = arr.length;
		System.out.print("Enter target");
		int t = sc.nextInt();
		for(int i = 0;i<(len-1);i++){
		    for(int j = (i+1);j<len;j++){
		        if (arr[i]+arr[j] == t){
		            System.out.print(i+","+j);
		        }
		    }
		}
	}
}
