class Solution {
    public int[] shuffle(int[] nums, int n) {
        n = (nums.length)/2;
        int[] ans = new int[2 * n];
        for(int i = 0;i<n;i++){
            ans[2*i] = nums[i];
            ans[2*i+1] = nums[i+n];
            }
        return ans;
    }
}
